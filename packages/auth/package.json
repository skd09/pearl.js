{
  "name": "@pearl-framework/auth",
  "version": "1.2.0",
  "description": "Pearl.js auth — JWT, session, and API token authentication guards",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "pearl",
    "pearljs",
    "auth",
    "jwt",
    "authentication",
    "scrypt",
    "typescript",
    "nodejs",
    "framework"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@pearl-framework/core": "workspace:*",
    "@pearl-framework/http": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pearl-js/pearl.js.git",
    "directory": "packages/auth"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ]
}
