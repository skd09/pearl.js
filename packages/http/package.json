{
    "name": "@pearl/http",
    "version": "0.1.0",
    "description": "Pearl.js HTTP kernel — router, middleware pipeline, request/response",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@pearl/core": "workspace:*",
        "reflect-metadata": "^0.2.2"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "typescript": "^5.4.0",
        "vitest": "^1.6.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/skd09/pearl.js.git",
        "directory": "packages/http"
    }
}