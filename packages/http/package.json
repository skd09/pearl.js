{
  "name": "@pearl-framework/http",
  "version": "1.0.0",
  "description": "Pearl.js HTTP kernel — router, middleware pipeline, request/response",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "pearl",
    "pearljs",
    "http",
    "router",
    "middleware",
    "rest-api",
    "typescript",
    "nodejs",
    "framework"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pearl-framework/core": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skd09/pearl.js.git",
    "directory": "packages/http"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "type": "module"
}
