{
  "name": "@pearl-framework/core",
  "version": "1.2.0",
  "description": "Pearl.js core — IoC container, application kernel, service providers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "pearl",
    "pearljs",
    "ioc",
    "container",
    "dependency-injection",
    "service-provider",
    "typescript",
    "nodejs",
    "framework"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pearl-js/pearl.js",
    "directory": "packages/core"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ]
}
