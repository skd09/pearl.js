{
  "name": "@pearl-framework/pearl",
  "version": "0.1.0",
  "description": "Pearl.js — The TypeScript framework that does it right.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "@pearl-framework/auth":     "workspace:*",
    "@pearl-framework/core":     "workspace:*",
    "@pearl-framework/database": "workspace:*",
    "@pearl-framework/events":   "workspace:*",
    "@pearl-framework/http":     "workspace:*",
    "@pearl-framework/mail":     "workspace:*",
    "@pearl-framework/queue":    "workspace:*",
    "@pearl-framework/validate": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript":  "^5.4.0"
  },
  "keywords": ["pearl", "framework", "typescript", "nodejs"],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}