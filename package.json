{
  "name": "Pearl.js",
  "version": "0.1.0",
  "private": true,
  "description": "A TypeScript framework for Node.js.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.0.0",
    "turbo": "^2.9.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "hono": "^4.12.23",
      "@hono/node-server": "^1.19.13",
      "esbuild": "^0.28.1",
      "effect": "^3.20.0",
      "defu": "^6.1.5",
      "lodash": "^4.18.1",
      "picomatch": "^4.0.4",
      "vite": "^6.4.3",
      "postcss": "^8.5.10",
      "brace-expansion": "^2.0.3",
      "js-yaml": "^4.2.0",
      "uuid": "^11.1.1",
      "vitest": "^3.2.6"
    }
  }
}
